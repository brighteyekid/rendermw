{
  "name": "rendermw",
  "version": "0.1.1",
  "description": "Zero-dependency data-driven dynamic rendering middleware for Express. No Puppeteer. No external services. Bots get semantic HTML. Users get your SPA.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "diagram.png",
    "logo.png"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "seo",
    "express",
    "middleware",
    "dynamic-rendering",
    "bot-detection",
    "spa",
    "react",
    "vue",
    "angular",
    "schema",
    "open-graph",
    "json-ld",
    "crawlers",
    "structured-data"
  ],
  "author": "Chandra Bhayal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brighteyekid/rendermw.git"
  },
  "bugs": {
    "url": "https://github.com/brighteyekid/rendermw/issues"
  },
  "homepage": "https://github.com/brighteyekid/rendermw#readme",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "supertest": "^6.0.0",
    "@types/supertest": "^2.0.0",
    "express": "^4.18.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
